# ─────────────────────────────────────────────────────────────
#  PRODUCTION ENVIRONMENT VARIABLES (Vercel)
#  Copy these keys into: Vercel → Project → Settings →
#  Environment Variables, and fill in real values.
#  This file is safe to commit (contains no secrets).
# ─────────────────────────────────────────────────────────────

# Neon — pooled connection string (used by the app at runtime).
# Format: postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL=

# Neon — direct (non-pooled) connection string (used only by prisma migrate).
# Same as above but WITHOUT "-pooler" in the hostname.
DIRECT_DATABASE_URL=

# JWT signing secret for session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Optional: seed admin user (only used by `bun run db:seed`) ──
SEED_ADMIN_EMAIL=admin@mvi.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrator
